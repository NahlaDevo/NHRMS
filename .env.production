# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://nhrms:nhrms_dev@localhost:5432/nhrms
POSTGRES_USER=nhrms
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=nhrms

# ── Auth ──────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App ──────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── Redis (for ARQ background jobs) ──────────────────
REDIS_URL=redis://localhost:6379/0

# ── Error Tracking ──────────────────────────────────
SENTRY_DSN=https://your-dsn@sentry.io/your-project
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── SMTP Email ──────────────────────────────────────
SMTP_SERVER=smtp.sendgrid.net
SMTP_PORT=465
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key

# ── LLM Provider ────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=

# ── File Storage ────────────────────────────────────
COMPANY_STORAGE_PATH=uploads
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.doc,.docx
