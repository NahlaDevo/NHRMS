# Database
DATABASE_URL=postgresql://nhrms:nhrms_dev@localhost:5432/nhrms
# DATABASE_URL=sqlite:///data/saas.db  # fallback for local dev without Docker

# Auth
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
DEBUG=true

# Redis (for ARQ background jobs)
REDIS_URL=redis://localhost:6379/0

# Sentry (optional)
SENTRY_DSN=

# SMTP Email (optional)
SMTP_SERVER=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# LLM Provider (optional: "openai" or "anthropic")
LLM_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com
