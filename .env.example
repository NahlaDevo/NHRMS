# ──────────────────────────────────────────
# NHRMS – Environment Configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────

# Database
DATABASE_URL=postgresql://nhrms:nhrms_dev@localhost:5432/nhrms
# DATABASE_URL=sqlite:///data/saas.db  # fallback for local dev without Docker

# Auth
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
DEBUG=true
ENVIRONMENT=development
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,https://nhrms-api.onrender.com,https://nhrms-frontend.onrender.com
FRONTEND_URL=https://nhrms-frontend.onrender.com

# Redis (for ARQ background jobs — set to Redis Cloud URL for workers)
REDIS_URL=redis://localhost:6379/0

# Sentry (optional — leave blank to disable)
SENTRY_DSN=

# SMTP Email (optional — leave blank to disable)
SMTP_SERVER=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# LLM Provider (optional: "openai" or "anthropic"; leave blank for rule-based scoring)
LLM_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# File storage
COMPANY_STORAGE_PATH=uploads

# Upload constraints
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.doc,.docx
